DB2_BASE_IMAGE=icr.io/db2_community/db2:11.5.9.0
DB2_PLATFORM=linux/amd64
DB2_IMAGE_NAME=docker-cookbook/db2-libfaketime:11.5.9.0
DB2_CONTAINER_NAME=db2-libfaketime
DB2_HOSTNAME=db2server
DB2_HOST_PORT=50000

LICENSE=accept
DB2INSTANCE=db2inst1
DB2INST1_PASSWORD=change-me-in-local-env
DBNAME=testdb
BLU=false
ENABLE_ORACLE_COMPATIBILITY=false
UPDATEAVAIL=NO
TO_CREATE_SAMPLEDB=false
REPODB=false
IS_OSXFS=false
PERSISTENT_HOME=true
HADR_ENABLED=false
ETCD_ENDPOINT=
ETCD_USERNAME=
ETCD_PASSWORD=

TZ=UTC

# Uncomment for time-travel testing. Leave empty for normal Db2 behavior.
# FAKETIME=@2024-01-02 03:04:05
FAKETIME=
FAKETIME_NO_CACHE=1
FAKETIME_DONT_FAKE_MONOTONIC=
FAKETIME_TIMESTAMP_FILE=
FAKETIME_FOLLOW_FILE=
FAKETIME_START_AFTER_SECONDS=
FAKETIME_STOP_AFTER_SECONDS=
FAKETIME_START_AFTER_NUMCALLS=
FAKETIME_STOP_AFTER_NUMCALLS=
FAKETIME_DISABLE_SHM=
